# ITS 국가교통정보센터 인증키
ITS_API_KEY=your_its_api_key_here

# ITS 스트림 방식 — HTTPS 배포에서는 4(HTTPS HLS) 권장. 미설정 시 기본값 4.
#ITS_CCTV_TYPE=4

# 대전시 공공데이터 인증키
DAEJEON_API_KEY=your_daejeon_service_key_here

# CCTV 캐시 TTL (초)
CACHE_TTL=900
STREAM_URL_MAX_AGE=180

# 정류장 반경 (미터)
MAX_DISTANCE=500

# 재생 가능(스트림 URL이 있는) 장비만 API/화면에 표시할지 — 1 권장(메타만 있는 빈 카드 방지).
PLAYABLE_ONLY=1

# 로그 상세도: debug | info | warn | error (기본 info)
LOG_LEVEL=info

# ITS cctvInfo 조회 시 노선 bbox를 도 단위로 추가 확장 — 국도 CCTV가 근처에 있으나 노선 상자에서 살짝 벗어날 때 도움(예: 0.02)
ITS_BBOX_EXTRA_PADDING=0.02
