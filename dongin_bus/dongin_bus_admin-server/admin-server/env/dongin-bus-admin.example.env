# 복사: cp env/dongin-bus-admin.example.env env/dongin-bus-admin.env 후 값 수정.
# env/dongin-bus-admin.env 는 커밋하지 마세요.
# SESSION_KEYS 는 서버 전용 .env(또는 Swarm secret)에만 두면 됩니다. 브라우저/nginx에는 불필요.

ADMIN_USER=dongin-admin
ADMIN_PASS=change-me-strong-password
SESSION_KEYS=replace-with-openssl-rand-hex-32,optional-second-key

# 페이지 통계: 기본 활성화. 다른 경로는 VISIT_DB_PATH 로 지정 가능.
#VISIT_DB_PATH=/srv/dongin_bus/_metrics/pageviews.sqlite
#VISIT_TRACKING_ENABLED=0
#COLLECT_RATE_LIMIT_PER_MINUTE=120

# CCTV 뷰어 정적 소스 (dit-admin 에서 index.html / data/routes.json 관리). 기본 켜짐.
#CCTV_ADMIN_ENABLED=0
# 생략 시 {DONGIN_BUS_DIR}/cctv_viewer (스택에서 /srv/dongin_bus/cctv_viewer)
#CCTV_VIEWER_DIR=/srv/dongin_bus/cctv_viewer
