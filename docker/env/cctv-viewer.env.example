# CCTV Viewer 환경 변수 설정 파일
# 서버 배포 시 이 파일을 복사하여 실제 값으로 수정하세요
# cp cctv-viewer.env.example cctv-viewer.env

# ITS 국가교통정보센터 인증키
ITS_API_KEY=your_its_api_key_here

# HTTPS 사이트에서 HLS 재생 시 4(HTTPS HLS) 권장. 미설정 시 API 기본 4.
#ITS_CCTV_TYPE=4

# 대전시 공공데이터 인증키  
DAEJEON_API_KEY=your_daejeon_api_key_here

# CCTV 캐시 TTL (초). 위치·이름 등 목록 보관. 기본 900(15분)
CACHE_TTL=900

# ITS HLS streamUrl 재발급 주기(초). 재접속 403 방지. 기본 180(3분)
STREAM_URL_MAX_AGE=180

# 정류장 반경 (미터, 기본값: 500m)
MAX_DISTANCE=500

# 재생 스트림 URL이 있는 장비만 노선 API에 포함 (1/true 권장 — 메타만 있는 빈 카드 방지). 미설정 시 기존처럼 전체 반환
PLAYABLE_ONLY=1

# ITS cctvInfo 조회 영역만 노선 bbox보다 추가 확장(도 단위). 국도 CCTV가 많이 포함되도록
ITS_BBOX_EXTRA_PADDING=0.02
